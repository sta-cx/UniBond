# ============================================
# UniBond 生产环境配置
# 复制此文件为 .env 并填写实际值
# ============================================

# ---- 数据库 ----
DB_USERNAME=unibond
DB_PASSWORD=你的数据库密码

# ---- JWT ----
# 至少 32 字符的随机字符串
JWT_SECRET=你的JWT密钥至少32字符以上

# ---- 邮件 (Outlook) ----
MAIL_HOST=smtp-mail.outlook.com
MAIL_PORT=587
MAIL_USERNAME=你的outlook邮箱
MAIL_PASSWORD=你的outlook密码

# ---- APNs (可选，暂时留空) ----
APNS_KEY_PATH=
APNS_KEY_ID=
APNS_TEAM_ID=
